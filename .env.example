# Backend
APP_ENV=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_AGENT_STEPS=6

# LLM provider: mock or openai
LLM_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Conversation storage (MySQL)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mmagent
MYSQL_CHARSET=utf8mb4

# Weather provider: open_meteo or openweather
WEATHER_PROVIDER=open_meteo
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.open-meteo.com
WEATHER_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com
WEATHER_LANGUAGE=en

# Web search provider
WEB_SEARCH_BASE_URL=https://api.duckduckgo.com
